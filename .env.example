# ─────────────────────────────────────────────────────────────
# RuleFlow environment configuration
# Copy to backend/.env (backend) and frontend/.env.local (frontend)
# ─────────────────────────────────────────────────────────────

# ---- Backend ----
# Database. Leave as sqlite for zero-infra local dev; use Postgres+pgvector for full features.
DATABASE_URL=sqlite:///./regnexus.db
# DATABASE_URL=postgresql+psycopg://regnexus:regnexus@localhost:5432/regnexus

# LLM (OpenRouter or Groq via LiteLLM). Model is swappable — the kernel is the trust layer.
# REQUIRED: the agent layer (extraction, cross-ref, applicability, inspector)
# runs on any LiteLLM-compatible model.
OPENROUTER_API_KEY=
GROQ_API_KEY=
LLM_MODEL=openrouter/google/gemini-2.5-flash
LLM_TEMPERATURE=0.0

# Embeddings for hybrid search. Leave blank to use the local hashing fallback.
EMBEDDING_MODEL=
EMBEDDING_DIM=1024

# Citation-fidelity gate threshold (>= this to accept an obligation).
CITATION_FIDELITY_THRESHOLD=0.95

# Object storage for original PDFs + evidence (S3-compatible, WORM/versioned).
STORAGE_BACKEND=local
STORAGE_DIR=./storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Temporal (workflows). Leave blank to disable in local dev.
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=default

# CORS: allowed frontend origins (comma separated)
CORS_ORIGINS=http://localhost:3000

# ---- Frontend (Vite React SPA) ----
VITE_API_URL=http://localhost:8000
